  <!-- PROGRAMS -->
  <section class="section" id="programs">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Programs</span>
        <h2>Four ways to swim with us</h2>
        <p class="lead">Whether your swimmer is just starting out, building skills, preparing for competitive swimming, or looking for an hour of lap swim before work, New Heights Aquatics is here for you.</p>
      </div>

      <div class="cards">

        <div class="card">
          <div class="card-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><circle cx="17" cy="9" r="3"/><path d="M2 20v-1a6 6 0 0 1 12 0v1"/><path d="M14 17a4 4 0 0 1 8 0v1"/></svg></div>
          <h3>Group Lessons</h3>
          <div class="price">$150 <small>/ 2-week session</small></div>
          <p>Small-class instruction with up to 5 swimmers per instructor. Three skill levels — Beginner, Intermediate, and Advanced.</p>
          <ul>
            <li>8 × 30-min classes · Mon–Thu, 2 weeks</li>
            <li>Classes available Mon–Thu · 9:00 AM – 12:00 PM</li>
            <li>Sessions start June 1</li>
          </ul>
          <a class="btn btn-secondary card-cta" href="group-lessons.html">See schedule</a>
        </div>

        <div class="card">
          <div class="card-icon accent"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg></div>
          <h3>Private Lessons</h3>
          <div class="price">$65 <small>/ 30 min</small></div>
          <p>One-on-one instruction tailored to your goals — whether it's building confidence, refining strokes, or preparing for a swim team tryout.</p>
          <ul>
            <li>All ages and abilities</li>
            <li>Personalized skill plan</li>
            <li>30, 45, or 60 minute sessions</li>
          </ul>
          <a class="btn btn-secondary card-cta" href="private-lessons.html">See schedule</a>
        </div>

        <div class="card">
          <div class="card-icon"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-8-4.5-8-11a5 5 0 0 1 9-3 5 5 0 0 1 9 3c0 6.5-8 11-8 11h-2Z"/></svg></div>
          <h3>Special Needs Lessons</h3>
          <div class="price">$70 <small>/ 45 min</small></div>
          <p>Adaptive, sensory-friendly lessons led by instructors with special needs certification. We partner with families to design each swimmer's plan.</p>
          <ul>
            <li>Sensory-aware environment</li>
            <li>1:1 or 2:1 instructor ratio</li>
            <li>Works with all diagnoses &amp; abilities</li>
          </ul>
          <a class="btn btn-secondary card-cta" href="register.html?program=special-45">Reserve a slot</a>
        </div>

        <div class="card">
          <div class="card-icon accent"><svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 15c2 0 3-2 5-2s3 2 5 2 3-2 5-2 3 2 5 2"/><path d="M2 20c2 0 3-2 5-2s3 2 5 2 3-2 5-2 3 2 5 2"/><circle cx="17" cy="7" r="2"/></svg></div>
          <h3>Adult Lap Swim</h3>
          <div class="price">$5 <small>/ 60 min session</small></div>
          <p>Drop in for a focused hour of lap swimming in our 6-lane pool. No membership required — reserve a lane online and show up.</p>
          <ul>
            <li>Ages 18+</li>
            <li>Slow, medium, and fast lanes</li>
            <li>Early morning &amp; weekend hours</li>
          </ul>
          <a class="btn btn-secondary card-cta" href="lap-swim.html">Reserve a lane</a>
        </div>

      </div>
    </div>
  </section>

